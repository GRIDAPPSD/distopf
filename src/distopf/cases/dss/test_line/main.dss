Clear 

new circuit.test_line
~ basekv=4.16 pu=1.000 phases=3 bus1=1  

New linecode.test nphases=3 BaseFreq=60 
~ rmatrix = (0.3 | 0.1 0.3 | 0.1 0.1 0.3 ) 
~ xmatrix = (1.0 | 0.5 1.0 | 0.5 0.5 1.0 ) 
~ units=mi 

!LINE DEFINITIONS 
New Line.12    Phases=3 Bus1=1.1.2.3   Bus2=2.1.2.3  LineCode=test Length=2000 units=ft 
New Line.23    Phases=3 Bus1=2.1.2.3   Bus2=3.1.2.3  LineCode=test Length=2000 units=ft 

!LOAD DEFINITIONS 
New Load.3a Bus1=3.1     Phases=1 Conn=Wye  Model=1 kV=2.40177  kW=1000   kvar=500 
New Load.3b Bus1=3.2     Phases=1 Conn=Wye  Model=1 kV=2.40177  kW=1000   kvar=500 
New Load.3c Bus1=3.3     Phases=1 Conn=Wye  Model=1 kV=2.40177  kW=1000   kvar=500 

Set Voltagebases=[4.16]
Set LoadMult=1.0
calcv
Solve

